datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/node_modules/.prisma/client"
}

// Enums

enum UserType {
  SYSTEM_USER
}

enum Role {
  ADMIN
  USER
  SALE
  PUMPIST
}

enum ShiftStatus {
  PLANNED
  OPEN
  CLOSED
  RECONCILED
}

enum ShopSalesSource {
  SHIFT_SUMMARY_ENTRY
  TRANSACTIONAL_SYSTEM_TOTAL
  MANUAL
}

// Models

// Login: API accepts "username" in request body; backend treats it as this email (no separate username field).
// Every User must be tied to a Worker; a Worker may have at most one User.
model User {
  id           Int       @id @default(autoincrement())
  workerId     Int       @unique
  name         String
  email        String    @unique
  passwordHash String
  role         Role
  userType     UserType  @default(SYSTEM_USER)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  worker              Worker                @relation(fields: [workerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  pumpReadings        PumpReading[]         @relation("PumpReadingRecordedBy")
  cashHandIns         CashHandIn[]          @relation("CashHandInRecordedBy")
  reviewedSummaries   ShiftReconciliationSummary[] @relation("SummaryReviewedBy")
  createdShopSales    ShopSale[]            @relation("ShopSaleCreatedBy")
  weeklyInventoryClosesRecorded WeeklyInventoryClose[] @relation("WeeklyInventoryCloseRecordedBy")

  @@map("users")
}

model Worker {
  id          Int       @id @default(autoincrement())
  name        String
  designation String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user              User?                @relation()
  shiftWorkers      ShiftWorker[]
  cashHandIns       CashHandIn[]
  pumpAssignments   ShiftPumpAssignment[]
  pumpReadings      PumpReading[]
  shopAccountableShifts     Shift[] @relation("ShopAccountableWorker")
  weeklyInventoryCloses     WeeklyInventoryClose[]

  @@map("workers")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?

  products Product[]

  @@map("categories")
}

model Product {
  id           Int       @id @default(autoincrement())
  name         String
  categoryId   Int
  sellingPrice Decimal   @db.Decimal(10, 2)
  currentStock Decimal    @db.Decimal(12, 3)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category             Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  purchasePriceHistory PurchasePriceHistory[]
  shopSaleItems        ShopSaleItem[]
  shiftProductStocks   ShiftProductStock[]
  weeklyInventoryCountLines WeeklyInventoryCountLine[]

  @@index([categoryId])
  @@map("products")
}

model PurchasePriceHistory {
  id            Int      @id @default(autoincrement())
  productId     Int
  purchasePrice Decimal  @db.Decimal(10, 2)
  effectiveAt   DateTime
  notes         String?

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([productId, effectiveAt])
  @@map("purchase_price_history")
}

model FuelType {
  id        Int      @id @default(autoincrement())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tanks        Tank[]
  priceHistory FuelPriceHistory[]

  @@map("fuel_types")
}

model Tank {
  id                      Int       @id @default(autoincrement())
  fuelTypeId               Int
  name                     String
  capacity                 Decimal?  @db.Decimal(12, 3)
  theoreticalQuantity      Decimal?  @db.Decimal(12, 3)
  actualQuantity           Decimal?  @db.Decimal(12, 3)
  actualQuantityRecordedAt DateTime?
  active                   Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  fuelType     FuelType           @relation(fields: [fuelTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  pumps        Pump[]
  deliveries   FuelDelivery[]
  levelReadings TankLevelReading[]

  @@index([fuelTypeId])
  @@map("tanks")
}

model FuelDelivery {
  id          Int      @id @default(autoincrement())
  tankId      Int
  quantity    Decimal  @db.Decimal(12, 3)
  deliveredAt DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tank Tank @relation(fields: [tankId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tankId, deliveredAt])
  @@map("fuel_deliveries")
}

model TankLevelReading {
  id                        Int       @id @default(autoincrement())
  tankId                    Int
  measuredAt                DateTime
  quantity                  Decimal   @db.Decimal(12, 3)
  theoreticalQuantityAtTime Decimal?   @db.Decimal(12, 3)
  createdAt                 DateTime  @default(now())

  tank Tank @relation(fields: [tankId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tankId, measuredAt])
  @@map("tank_level_readings")
}

model Pump {
  id     Int     @id @default(autoincrement())
  name   String
  active Boolean @default(true)
  tankId Int?

  tank        Tank?                 @relation(fields: [tankId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  readings    PumpReading[]
  assignments ShiftPumpAssignment[]

  @@index([tankId])
  @@map("pumps")
}

model FuelPriceHistory {
  id            Int      @id @default(autoincrement())
  fuelTypeId    Int
  pricePerUnit  Decimal  @db.Decimal(10, 2)
  purchasePricePerUnit Decimal? @db.Decimal(10, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?

  fuelType FuelType @relation(fields: [fuelTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([fuelTypeId, effectiveFrom, effectiveTo])
  @@map("fuel_price_history")
}

model Shift {
  id        Int       @id @default(autoincrement())
  date      DateTime
  startTime DateTime
  endTime   DateTime
  status    ShiftStatus
  notes     String?

  /** Optional designated shop seller for defaults (cash hand-in, weekly close). */
  shopAccountableWorkerId Int?

  workers             ShiftWorker[]
  pumpReadings        PumpReading[]
  cashHandIns         CashHandIn[]
  reconciliation      ShiftReconciliationSummary?
  shopSales           ShopSale[]
  productStocks       ShiftProductStock[]
  pumpAssignments     ShiftPumpAssignment[]

  shopAccountableWorker Worker? @relation("ShopAccountableWorker", fields: [shopAccountableWorkerId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([date])
  @@index([status])
  @@index([shopAccountableWorkerId])
  @@map("shifts")
}

model ShiftWorker {
  shiftId  Int
  workerId Int

  shift  Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  worker Worker @relation(fields: [workerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([shiftId, workerId])
  @@index([shiftId])
  @@index([workerId])
  @@map("shift_workers")
}

model ShiftProductStock {
  shiftId    Int
  productId  Int
  openingQty Decimal @db.Decimal(12, 3)
  /** Stock received during the shift (purchases/deliveries), per physical shop book. */
  receivedQty Decimal @default(0) @db.Decimal(12, 3)
  closingQty Decimal @db.Decimal(12, 3)

  shift   Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([shiftId, productId])
  @@index([shiftId, productId])
  @@map("shift_product_stocks")
}

model PumpReading {
  id              Int      @id @default(autoincrement())
  pumpId          Int
  shiftId         Int
  openingReading  Decimal  @db.Decimal(12, 3)
  closingReading  Decimal  @db.Decimal(12, 3)
  recordedById    Int
  recordedAt      DateTime @default(now())
  workerId        Int?

  pump        Pump @relation(fields: [pumpId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  shift       Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recordedBy  User @relation("PumpReadingRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  worker      Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([shiftId, pumpId])
  @@map("pump_readings")
}

model ShiftPumpAssignment {
  shiftId  Int
  pumpId   Int
  workerId Int

  shift  Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pump   Pump   @relation(fields: [pumpId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  worker Worker @relation(fields: [workerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([shiftId, pumpId])
  @@index([workerId])
  @@index([shiftId, pumpId])
  @@map("shift_pump_assignments")
}

model CashHandIn {
  id           Int      @id @default(autoincrement())
  shiftId      Int
  workerId     Int
  amount       Decimal  @db.Decimal(10, 2)
  /** Optional variance at hand-in time: positive = missing / short; negative = surplus. */
  varianceAmount Decimal? @db.Decimal(10, 2)
  varianceNote   String?
  recordedById Int
  recordedAt   DateTime @default(now())

  shift      Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  worker     Worker @relation(fields: [workerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  recordedBy User   @relation("CashHandInRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([shiftId, workerId])
  @@map("cash_hand_ins")
}

model ShiftReconciliationSummary {
  id                     Int             @id @default(autoincrement())
  shiftId                Int             @unique
  shopSalesSource        ShopSalesSource
  systemShopSalesTotal   Decimal?        @db.Decimal(10, 2)
  manualShopSalesTotal   Decimal?        @db.Decimal(10, 2)
  effectiveShopSalesTotal Decimal        @db.Decimal(10, 2)
  manualShopSalesReason  String?
  fuelSalesTotal         Decimal         @db.Decimal(10, 2)
  fuelSalesOverrideReason String?
  cashHandedTotal        Decimal         @db.Decimal(10, 2)
  cashHandedTotalOverrideReason String?
  discrepancyAmount      Decimal         @db.Decimal(10, 2)
  reviewedById           Int?
  notes                  String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  shift      Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewedBy User? @relation("SummaryReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([shiftId])
  @@map("shift_reconciliation_summaries")
}

model ShopSale {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  totalAmount  Decimal  @db.Decimal(10, 2)
  createdById  Int?
  shiftId      Int?

  createdBy User?   @relation("ShopSaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  shift     Shift?  @relation(fields: [shiftId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items     ShopSaleItem[]

  @@map("shop_sales")
}

model ShopSaleItem {
  id             Int      @id @default(autoincrement())
  shopSaleId     Int
  productId      Int
  quantity       Decimal  @db.Decimal(12, 3)
  unitPriceAtSale Decimal @db.Decimal(10, 2)
  lineTotal      Decimal  @db.Decimal(10, 2)

  sale    ShopSale @relation(fields: [shopSaleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("shop_sale_items")
}

/** Authoritative weekly physical close for payroll (enforced shortfall vs daily book). */
model WeeklyInventoryClose {
  id                 Int      @id @default(autoincrement())
  weekStart          DateTime @db.Date
  weekEnd            DateTime @db.Date
  workerId           Int
  /** Positive = shortage (cash owed / loss). */
  enforcedShortfall  Decimal  @db.Decimal(10, 2)
  notes              String?
  physicalCountAt    DateTime?
  recordedById       Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  worker     Worker @relation(fields: [workerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  recordedBy User   @relation("WeeklyInventoryCloseRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lines      WeeklyInventoryCountLine[]

  @@unique([weekStart, workerId])
  @@index([weekStart, weekEnd])
  @@index([workerId])
  @@map("weekly_inventory_closes")
}

model WeeklyInventoryCountLine {
  id                     Int @id @default(autoincrement())
  weeklyInventoryCloseId Int
  productId              Int
  physicalQty            Decimal @db.Decimal(12, 3)

  weeklyInventoryClose WeeklyInventoryClose @relation(fields: [weeklyInventoryCloseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product              Product              @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([weeklyInventoryCloseId, productId])
  @@index([weeklyInventoryCloseId])
  @@map("weekly_inventory_count_lines")
}

model FixedCost {
  id            Int      @id @default(autoincrement())
  name          String
  monthlyAmount Decimal  @db.Decimal(10, 2)
  effectiveMonth DateTime
  notes         String?

  @@map("fixed_costs")
}

