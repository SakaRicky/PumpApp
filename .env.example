# Database (API)
# Local:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/pumpapp"
# Supabase (use Session Pooler / Transaction in dashboard — required for IPv4):
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
# API server
PORT=5000
JWT_SECRET="change-me"
# Web app: API base URL (for Vite)
VITE_API_URL="http://localhost:5000/api"
# Optional: money unit label shown next to prices (e.g. XAF for Cameroon). Single unit only; no conversion.
# VITE_CURRENCY_LABEL="XAF"
